DJANGO_ENV=development
SECRET_KEY=your-secret-key-here
DEBUG=True
USE_SQLITE=False
USE_REDIS=False
ENABLE_DEFENDER=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated list of allowed CORS origins.
# For production, replace with your actual frontend domain AND include the Capacitor mobile origins:
#   capacitor://localhost  — Android app (default Capacitor scheme)
#   https://localhost      — Android app when androidScheme=https is set in capacitor.config.ts
# Example production value:
#   CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,capacitor://localhost,https://localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,capacitor://localhost,https://localhost
CSRF_TRUSTED_ORIGINS=
APP_SIGNING_SECRET=change-this-app-signing-secret

# Django Admin URL — change this to something unpredictable in production (do NOT use 'admin/')
DJANGO_ADMIN_URL=admin-s2w-secure/

# Admin panel registration gate — required, no default (registration disabled if unset)
ADMIN_REGISTRATION_CODE=change-this-to-a-random-secret

# Render/hosted PostgreSQL (preferred in production)
DATABASE_URL=

DB_NAME=step2win
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=django-db

# Optional production hardening
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Optional override if you need to relax or tighten the default CSP
CONTENT_SECURITY_POLICY=

SENTRY_DSN=

# PochPay Payment Gateway
POCHIPAY_EMAIL=your-pochipay-email@company.com
POCHIPAY_PASSWORD=YourSecurePa$$w0rd
# PochPay webhook signature secret — set this to verify callbacks come from PochPay
POCHIPAY_WEBHOOK_SECRET=your-pochipay-webhook-secret

# PochPay Callback URLs (must be publicly accessible, NO auth)
# For development, use ngrok: https://your-ngrok-url.ngrok.io/api/payments/mpesa/deposit-callback/
POCHIPAY_DEPOSIT_CALLBACK_URL=https://api.step2win.com/api/payments/mpesa/deposit-callback/
POCHIPAY_PAYOUT_CALLBACK_URL=https://api.step2win.com/api/payments/mpesa/payout-callback/
POCHIPAY_WITHDRAWAL_CALLBACK_URL=https://api.step2win.com/api/payments/mpesa/withdrawal-callback/
