# Google OAuth Configuration
# Get your Client ID from: https://console.cloud.google.com/
# 1. Create a new project in Google Cloud Console
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized JavaScript origins:
#    - http://localhost:5173 (for dev)
#    - http://127.0.0.1:5173 (for dev)
#    - Your production domain
# 5. Copy the Client ID here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Backend API base URL (no trailing slash)
# Development:  http://127.0.0.1:8000
# Production:   https://your-backend.onrender.com  (or Railway domain)
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: explicit WebSocket base URL for real-time group chat.
# If omitted, VITE_API_BASE_URL is used with http→ws / https→wss substitution.
# Example production value: wss://your-backend.onrender.com
VITE_WS_URL=

# HMAC signing secret for step-sync requests — MUST match APP_SIGNING_SECRET in the backend.
# Generate a long random string (50+ chars) and set the same value in both places.
VITE_APP_SIGNING_SECRET=change-me-to-a-long-random-secret

# App version string sent to the backend during login for session tracking.
VITE_APP_VERSION=1.0.0
