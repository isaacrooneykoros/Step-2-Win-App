# Google OAuth Configuration
# Get your Client ID from: https://console.cloud.google.com/
# 1. Create a new project in Google Cloud Console
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized JavaScript origins:
#    - http://localhost:5173 (for dev)
#    - http://127.0.0.1:5173 (for dev)
#    - Your production domain
# 5. Copy the Client ID here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Backend API base URL
# Development default: http://localhost:8000
# Android emulator: http://10.0.2.2:8000
VITE_API_BASE_URL=http://localhost:8000

# App signing secret — must match APP_SIGNING_SECRET in backend/.env
# IMPORTANT: This value is embedded in the JavaScript bundle and is visible to anyone
# who inspects the app. Its primary purpose is to raise the bar for casual abuse;
# it does NOT provide cryptographic security. Rotate it together with the backend secret.
# Generate a value with: python -c "import secrets; print(secrets.token_urlsafe(48))"
VITE_APP_SIGNING_SECRET=change-me-in-production
